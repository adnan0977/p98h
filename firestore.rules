rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - uid: string (required) - The user's unique ID
    //   - email: string (required) - The user's email address
    //   - displayName: string (optional) - The user's display name
    //   - role: string (required) - 'admin' or 'user'
    //   - preferences: map (optional) - User settings
    //
    // ===============================================================

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "adnan0977@gmail.com");
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.uid is string && 
             data.email is string &&
             (data.role == 'user' || data.role == 'admin');
    }

    function isValidHadith(data) {
      return (data.number is int || data.number is string) &&
             data.arab is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow get: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow list, delete: if isAdmin();
    }

    match /quran_editions/{editionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /quran_edition_types/{typeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /languages/{languageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /hadith_books/{bookId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /hadith_editions/{editionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /hadith_index/{chapterId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /hadith_content/{bookId}/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /videos/{videoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /app_settings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /zakat_records/{recordId} {
      allow read, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /tasbih_history/{historyId} {
      allow read, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /quran_content/{editionId}/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
